# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=microservices-assignment
ENVIRONMENT=development

# --- Database (adjust to your chosen DB) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=admin
DB_PASSWORD=changeme

# --- Service Ports ---
CUSTOMER_SERVICE_PORT=5001
MOVIE_SERVICE_PORT=5002
SEAT_SERVICE_PORT=5003
BOOKING_SERVICE_PORT=5004
PAYMENT_SERVICE_PORT=5005
NOTIFICATION_SERVICE_PORT=5006
GATEWAY_PORT=8081
FRONTEND_PORT=3000

# --- API Gateway ---
GATEWAY_SECRET=your-gateway-secret

# --- Add more variables as needed for your stack ---
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://localhost:5672
# JWT_SECRET=your-jwt-secret
