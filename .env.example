# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=cinebook
ENVIRONMENT=development

# --- Database ---
# Các service sử dụng H2 in-memory database (embedded)
# Không cần cấu hình DB server bên ngoài
# H2 tự khởi tạo schema khi service start (ddl-auto: create-drop)

# --- Service Ports ---
CUSTOMER_SERVICE_PORT=5001
MOVIE_SERVICE_PORT=5002
SEAT_SERVICE_PORT=5003
BOOKING_SERVICE_PORT=5004
PAYMENT_SERVICE_PORT=5005
NOTIFICATION_SERVICE_PORT=5006
GATEWAY_PORT=8081
FRONTEND_PORT=3000

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Inter-service URLs (Docker Compose internal DNS) ---
CUSTOMER_SERVICE_URL=http://customer-service:5000
SEAT_SERVICE_URL=http://seat-availability-service:5000
BOOKING_SERVICE_URL=http://ticket-booking-service:5000

# --- Email (Notification Service) ---
# Điền thông tin SMTP để gửi email thực tế
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
